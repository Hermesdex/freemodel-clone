# FreeModel Clone - Environment Variables
# Copy this to .env.local and fill in your values

# Telegram Bot (for AgentHub OTP verification)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=

# Telegram Gateway (OTP via Telegram notification - legacy)
TELEGRAM_GATEWAY_API_TOKEN=your_gateway_token_here

# AgentHub / Supabase (server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
OTP_SIGNING_KEY=*** Vercel (for deployment)
VERCEL_TOKEN=your_vercel_token_here
# GitHub (for CI/CD)
GITHUB_TOKEN=your_github_token_here
# App
NEXT_PUBLIC_APP_URL=https://freemodel.dev
NEXT_PUBLIC_APP_NAME=FreeModel